# Copy to ".env" for local dev. On Netlify, set this in the dashboard instead
# (Site settings → Environment variables).
#
# Base URL of the backend API (note the trailing /api). Locally this defaults to
# http://localhost:4000/api if unset. In production point it at Render:
#   VITE_API_URL=https://the-last-signal-api.onrender.com/api
VITE_API_URL=http://localhost:4000/api
