# Copy this file to ".env" and adjust as needed.

# Port the API server listens on.
PORT=4000

# Secret used to sign JWT access tokens. CHANGE THIS in production —
# use a long random string (e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`).
JWT_SECRET=dev-insecure-secret-change-me

# How long an access token stays valid (zeit/ms format: 15m, 12h, 7d, 30d).
JWT_EXPIRES_IN=7d

# Where the SQLite database file lives (relative to the backend folder).
DB_FILE=./data/the-last-signal.db

# Comma-separated list of allowed browser origins, or * for any.
# The Vite dev server runs on http://localhost:5173.
CORS_ORIGIN=http://localhost:5173

# bcrypt cost factor for password hashing (10-12 is a good range).
BCRYPT_ROUNDS=10
