# Copy this file to ".env" and fill in your values.
# (Windows PowerShell: copy .env.example .env)

# ── Online database: Aiven for PostgreSQL ────────────────────────────────────
# Create a free PostgreSQL service at https://aiven.io, open the service, and copy
# its "Service URI" from the Connection information panel. It looks like:
#   postgres://avnadmin:PASSWORD@pg-xxxx.aivencloud.com:12345/defaultdb?sslmode=require
DATABASE_URL=postgres://avnadmin:PASSWORD@HOST:PORT/defaultdb?sslmode=require

# TLS: 'require' (default — Aiven needs it) or 'disable' (only for a local non-TLS Postgres).
DATABASE_SSL=require

# Optional: Aiven CA certificate to fully verify the server (download "CA Certificate"
# from the Aiven console). Provide a file path or the PEM contents. If omitted, the
# connection still uses TLS but does not verify the CA.
# DATABASE_CA_CERT=./ca.pem

# ── API server ───────────────────────────────────────────────────────────────
PORT=4000

# Secret used to sign JWT access tokens. CHANGE THIS — generate a random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-insecure-secret-change-me

# How long an access token stays valid (15m, 12h, 7d, 30d).
JWT_EXPIRES_IN=7d

# Comma-separated allowed browser origins, or * for any.
# The Vite dev server runs on http://localhost:5173.
CORS_ORIGIN=http://localhost:5173

# bcrypt cost factor for password hashing (10-12 is a good range).
BCRYPT_ROUNDS=10
